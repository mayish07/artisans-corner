{
  "version": 2,
  "builds": [
    {
      "src": "server/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server/server.js"
    },
    {
      "src": "/favicon.ico",
      "dest": "client/dist/favicon.ico"
    },
    {
      "src": "/favicon.png",
      "dest": "client/dist/favicon.png"
    },
    {
      "src": "/assets/(.*)",
      "dest": "client/dist/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "server/server.js"
    }
  ]
}